# GigShift backend environment variables
# Copy this file to `.env` (same folder) and fill in values as available.
# Missing keys fall back to safe defaults: mock GLM responses, seeded data.

# --- Flask ---
SECRET_KEY=change-me-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# --- Z.AI GLM ---
# If empty, the backend returns mock plan-shaped responses (see glm_service.py).
ZAI_API_KEY=
ZAI_API_URL=https://api.z.ai/v1

# --- OpenWeather (optional) ---
# If empty, weather falls back to a seeded daily_signals JSON.
OPENWEATHER_API_KEY=

# --- Database ---
# Defaults to ./gigshift.db if unset.
GIGSHIFT_DB_PATH=
